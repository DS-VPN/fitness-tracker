# SQLite database file path. Only used when running outside Docker (e.g. `npm run dev`) —
# docker-compose.yml sets this to /data/fitness.db for you, pointing at the persisted volume.
DATABASE_URL=local.db

# Single-user auth — change both of these before deploying
AUTH_PASSWORD=changeme
SESSION_SECRET=change-this-to-a-long-random-string

# Host port to publish (the container always listens on 3000 internally)
PORT=3000

# The URL you'll actually reach this app at (e.g. your Tailscale hostname or LAN IP), including
# the port. Required for Docker deployments — SvelteKit uses it to validate form submissions.
# Example: http://100.64.1.2:3000 or http://homeserver.tailnet-name.ts.net:3000
ORIGIN=http://localhost:3000
