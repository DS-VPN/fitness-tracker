# SQLite database file path. Only used when running outside Docker (e.g. `npm run dev`) —
# docker-compose.yml sets this to /data/fitness.db for you, pointing at the persisted volume.
DATABASE_URL=local.db

# Host port to publish (the container always listens on 3000 internally)
PORT=3000

# The URL you'll actually reach this app at (e.g. your Tailscale hostname or LAN IP), including
# the port. Required for Docker deployments — SvelteKit uses it to validate form submissions.
# Example: http://100.64.1.2:3000 or http://homeserver.tailnet-name.ts.net:3000
ORIGIN=http://localhost:3000

# Auth is per-account (username + password, created via the app's own "Create account" page) —
# there's nothing to configure here. Accounts and their data live entirely in the SQLite database.

# Encryption key for progress photos, which are stored encrypted (AES-256-GCM) at rest. Must decode to
# exactly 32 bytes; base64 or hex both work. Generate one with:  openssl rand -base64 32
# Required for the progress-photo feature — if unset, photo upload/viewing is disabled (everything else
# works). BACK THIS UP alongside your database: lose the key and existing photos become unrecoverable.
PHOTO_ENCRYPTION_KEY=
